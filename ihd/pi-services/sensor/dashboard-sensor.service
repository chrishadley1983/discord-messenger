[Unit]
Description=Dashboard BME280 Sensor API
After=network.target

[Service]
Type=simple
User=chrishadley1983
WorkingDirectory=/home/chrishadley1983/sensor-api
ExecStart=/home/chrishadley1983/sensor-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 5000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
