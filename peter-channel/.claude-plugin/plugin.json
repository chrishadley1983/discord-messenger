{
  "name": "peter-channel",
  "version": "0.0.1",
  "description": "Discord channel bridge for Peter — pushes messages from #peter-channel-test into a persistent Claude Code session",
  "channels": [
    {
      "server": "peter-channel"
    }
  ],
  "mcpServers": {
    "peter-channel": {
      "command": "npx",
      "args": ["tsx", "src/index.ts"],
      "cwd": ".",
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}",
        "DISCORD_CHANNEL_ID": "${DISCORD_CHANNEL_ID}",
        "ALLOWED_DISCORD_IDS": "${ALLOWED_DISCORD_IDS}"
      }
    }
  }
}
